# ============================================
# Receipt Verification System — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# ---- Database (Supabase) ----
# From supabase.com → your project → Connect:
# DATABASE_URL = "Transaction pooler" URI (port 6543)
#   pgbouncer=true is required on the transaction pooler (disables prepared
#   statements); connection_limit=1 stops each serverless instance from
#   opening its own pool and exhausting Supabase connections.
# DIRECT_URL   = "Session pooler" URI (port 5432) — used for prisma db push/migrations
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production-min-32-chars"

# ---- Verifier API (Vixen878/verifier-api) ----
# Hosted instance of https://github.com/Vixen878/verifier-api
# Get a free API key at https://verify.leul.et
VERIFIER_API_URL="https://verifyapi.leulzenebe.pro"
VERIFIER_API_KEY="your-verifier-api-key"

# ---- Optional hosted OCR fallback (OCR.Space) ----
# Exact PDF text and QR decoding stay on-device. When both flags are true,
# receipt images that still need OCR are compressed in the browser and sent
# through the authenticated /api/ocr route. Keep the API key server-side.
OCR_FALLBACK_ENABLED="false"
NEXT_PUBLIC_OCR_FALLBACK_ENABLED="false"
OCR_SPACE_API_KEY=""
# Safety limits below OCR.Space's public free-tier limits.
OCR_RATE_LIMIT_PER_MINUTE="10"
OCR_DAILY_LIMIT="450"

# ---- Demo Mode ----
# Set to "true" to run without a database (mock data for dashboard/history).
# If VERIFIER_API_KEY is set, receipt verification still uses the real API.
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"

# ---- Social login (optional — each provider activates when its keys are set) ----
# Google: https://console.cloud.google.com/apis/credentials (OAuth client, redirect URI:
#   https://YOUR-DOMAIN/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_AUTH_GOOGLE="false"
# Meta/Facebook: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
NEXT_PUBLIC_AUTH_FACEBOOK="false"
# Apple: requires an Apple Developer account
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
NEXT_PUBLIC_AUTH_APPLE="false"

# ---- Password recovery email (Resend) ----
# Use a sender on a domain you have verified in Resend.
RESEND_API_KEY=""
PASSWORD_RESET_FROM_EMAIL="ReceiptGuard <no-reply@your-domain.com>"

# ---- Encryption ----
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-for-account-numbers"

# ---- File Storage ----
UPLOAD_DIR="./uploads"

# ---- App Config ----
NEXT_PUBLIC_APP_NAME="ReceiptGuard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
