# ============================================
# Receipt Verification System — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# ---- Database ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/receipt_verify?schema=public"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production-min-32-chars"

# ---- Verifier API ----
VERIFIER_API_URL="https://verifier-api.onrender.com"
VERIFIER_API_KEY="your-verifier-api-key"

# ---- Encryption ----
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-for-account-numbers"

# ---- File Storage ----
UPLOAD_DIR="./uploads"

# ---- App Config ----
NEXT_PUBLIC_APP_NAME="ReceiptGuard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
