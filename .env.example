# ============================================
# Receipt Verification System — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# ---- Database ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/receipt_verify?schema=public"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production-min-32-chars"

# ---- Verifier API (Vixen878/verifier-api) ----
# Hosted instance of https://github.com/Vixen878/verifier-api
# Get a free API key at https://verify.leul.et
VERIFIER_API_URL="https://verifyapi.leulzenebe.pro"
VERIFIER_API_KEY="your-verifier-api-key"

# ---- Demo Mode ----
# Set to "true" to run without a database (mock data for dashboard/history).
# If VERIFIER_API_KEY is set, receipt verification still uses the real API.
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"

# ---- Encryption ----
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-for-account-numbers"

# ---- File Storage ----
UPLOAD_DIR="./uploads"

# ---- App Config ----
NEXT_PUBLIC_APP_NAME="ReceiptGuard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
